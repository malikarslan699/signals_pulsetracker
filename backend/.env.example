# =============================================================================
# PulseSignal Pro — Backend Environment Configuration
# Domain: signals.pulsetracker.net
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://pulsesignal:strongpassword@localhost:5432/pulsesignal_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Security / JWT
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=4f8b2c1d9e6a3f7b0d5e8c2a1f4b9e6d3c0f7a4b1e8d5c2a9f6b3e0d7c4a1b8e5
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Binance API (Futures)
# -----------------------------------------------------------------------------
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_WS_URL=wss://fstream.binance.com/ws
BINANCE_REST_URL=https://fapi.binance.com

# -----------------------------------------------------------------------------
# TwelveData API (Forex / Indices)
# -----------------------------------------------------------------------------
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_VIP_CHANNEL_ID=-1001234567890

# -----------------------------------------------------------------------------
# Stripe Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
STRIPE_LIFETIME_PRICE_ID=price_your_lifetime_price_id_here

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
FRONTEND_URL=https://signals.pulsetracker.net
BACKEND_URL=https://signals.pulsetracker.net

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Scanner / Engine Settings
# -----------------------------------------------------------------------------
MIN_SIGNAL_CONFIDENCE=60
SCANNER_INTERVAL_MINUTES=10
MAX_CANDLES_CACHE=500
